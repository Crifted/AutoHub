<%- include('partials/head') %>
<%- include('partials/navigatie', { actief: 'contact' }) %>
<header class="page-head"><div class="wrap"><span class="eyebrow">Contact</span><h1>Kom in contact</h1><p>Vragen over een auto of een proefrit plannen? We helpen je graag.</p></div></header>
<section class="section-pad" style="padding-top:56px;"><div class="wrap contact-layout">
  <div class="reveal">
    <div class="contact-info-item"><div class="ic"><svg viewBox="0 0 24 24"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.6A2 2 0 014.1 2h3a2 2 0 012 1.7c.1.9.3 1.8.6 2.6a2 2 0 01-.5 2.1L8.1 9.9a16 16 0 006 6l1.5-1.1a2 2 0 012.1-.5c.8.3 1.7.5 2.6.6a2 2 0 011.7 2z"/></svg></div><div><h4>Telefoon</h4><p>+31 (0)20 123 4567</p></div></div>
    <div class="contact-info-item"><div class="ic"><svg viewBox="0 0 24 24"><path d="M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2z"/><path d="M22 6l-10 7L2 6"/></svg></div><div><h4>E-mail</h4><p>info@autohub.nl</p></div></div>
    <div class="contact-info-item"><div class="ic"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div><div><h4>Showroom</h4><p>Autoweg 1, 1234 AB Amsterdam</p></div></div>
  </div>
  <div class="form-card reveal" style="padding:36px;">
    <% if (succes){ %><div class="note note-ok">Bedankt! Je bericht is verzonden. We nemen snel contact op.</div><% } %>
    <% if (fout){ %><div class="note note-bad"><%= fout %></div><% } %>
    <form action="/contact" method="POST">
      <div class="field-grid">
        <div class="field"><label>Naam</label><input type="text" name="naam" required></div>
        <div class="field"><label>E-mail</label><input type="email" name="email" required></div>
      </div>
      <div class="field"><label>Telefoon (optioneel)</label><input type="tel" name="telefoon"></div>
      <div class="field"><label>Onderwerp</label><input type="text" name="onderwerp" required></div>
      <div class="field"><label>Bericht</label><textarea name="bericht" required></textarea></div>
      <button class="btn btn-hot btn-lg">Verstuur bericht</button>
    </form>
  </div>
</div></section>
<%- include('partials/footer') %>
