<%- include('../partials/head') %>
<%- include('../partials/navigatie', { actief: 'admin' }) %>
<div class="wrap admin-shell">
  <span class="eyebrow">Beheer</span><h1 style="font-size:40px;">Berichten</h1>
  <%- include('../partials/admin-nav', { adminPagina: 'berichten' }) %>
  <% if (berichten.length===0){ %><div class="empty"><p>Nog geen berichten.</p></div><% } else { %>
    <% berichten.forEach(function(b){ %>
      <div class="msg-card reveal">
        <div class="msg-head"><div><strong><%= b.naam %></strong> <span class="muted"><%= b.email %></span></div><span class="msg-meta"><%= new Date(b.verzonden_op).toLocaleDateString('nl-NL') %></span></div>
        <div style="margin-bottom:10px;"><span class="status-badge st-aangevraagd"><%= b.onderwerp %></span><% if(b.telefoon){ %> <span class="muted"><%= b.telefoon %></span><% } %></div>
        <p style="font-size:14px;"><%= b.bericht %></p>
      </div>
    <% }) %>
  <% } %>
</div>
<%- include('../partials/footer') %>
