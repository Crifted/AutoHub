# ============================================================
# AUTOHUB - omgevingsvariabelen
# Kopieer dit bestand naar ".env" en vul je eigen waarden in.
# Het .env bestand zelf wordt NIET gedeeld (staat in .gitignore)
# ============================================================

# --- Server ---
PORT=3000

# --- MySQL database (MAMP) ---
# Standaard MAMP poort is 8889, soms 3306. Pas aan indien nodig.
DB_HOST=localhost
DB_PORT=8889
DB_USER=root
DB_PASSWORD=root
DB_NAME=autohub

# --- Beveiliging ---
# Verander dit in een eigen lange willekeurige tekst voordat je live gaat
JWT_SECRET=verander-dit-in-een-lange-geheime-sleutel-12345
SESSION_SECRET=verander-dit-ook-in-iets-geheims-67890
